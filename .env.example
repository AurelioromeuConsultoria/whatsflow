# Copie para .env e ajuste. Em produção (Coolify), defina como variáveis de ambiente.

# Banco
POSTGRES_DB=whatsflow
POSTGRES_USER=whatsflow
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_PORT=5432

# API
API_PORT=8080
# Chave JWT (HS256) — use uma string longa e aleatória em produção.
JWT_KEY=troque-por-uma-chave-longa-e-aleatoria-com-no-minimo-32-bytes

# Admin (SPA). URL PÚBLICA da API, embutida no bundle em build-time.
# Local: http://localhost:8080 | Produção: https://api.seudominio.com.br
VITE_API_URL=http://localhost:8080
ADMIN_PORT=5173

# Opcional — provider WhatsApp (Evolution). Vazio = usar provider Fake (dev).
# EVOLUTIONAPI__BASEURL=
# EVOLUTIONAPI__APIKEY=
# EVOLUTIONAPI__INSTANCENAME=
